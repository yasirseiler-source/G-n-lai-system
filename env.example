# Wiseness Dashboard – Umgebungsvariablen
# Kopiere diese Datei als .env und trage die echten Werte ein

# Resend API Key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-Mail: Absender (muss in Resend verifiziert sein)
MAIL_FROM=noreply@yourdomain.com

# E-Mail: Empfänger (wohin Anfragen gesendet werden)
MAIL_TO=info@yourdomain.com

# WhatsApp-Nummer (Ländervorwahl ohne + oder 00, z.B. 4915112345678)
WHATSAPP_NUMBER=4915112345678

# Vorbereitete WhatsApp-Nachricht (optional, wird URL-encodiert)
WHATSAPP_DEFAULT_MESSAGE=Merhaba, bir soru sormak istiyorum.

# Express-Server Port
PORT=3001
