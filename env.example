# Wiseness Dashboard – Umgebungsvariablen
# Kopiere diese Datei als .env und trage die echten Werte ein

# ── Supabase (Frontend) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Resend (Server / API) ────────────────────────────────────────────────────
# API Key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-Mail: Absender (muss in Resend verifiziert sein)
MAIL_FROM=noreply@yourdomain.com

# E-Mail: Empfaenger (wohin Anfragen gesendet werden)
MAIL_TO=info@yourdomain.com

# ── WhatsApp (Frontend, optional) ────────────────────────────────────────────
# Nummer mit Laendervorwahl ohne + oder 00 (z.B. 4915112345678)
VITE_WHATSAPP_NUMBER=4915112345678
VITE_WHATSAPP_MSG=Merhaba, bir soru sormak istiyorum.

# ── Express-Server Port (nur lokale Entwicklung) ─────────────────────────────
PORT=3001
